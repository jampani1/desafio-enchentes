# =====================================
# Local development
# =====================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=desafio_enchentes
PORT=3000
JWT_SECRET=

# =====================================
# Produção (Render)
# =====================================
# Quando o web service Render eh linkado a um Postgres gerenciado, o Render
# injeta DATABASE_URL automaticamente. db/index.js detecta a presenca dela
# e usa preferencialmente sobre os DB_* individuais.
# DATABASE_URL=postgres://user:pass@host:port/dbname
#
# Restringir CORS aos dominios do frontend em producao (separados por virgula).
# Sem essa var, o servidor libera todas origens (dev mode).
# FRONTEND_URL=https://desafio-enchentes-front.onrender.com
